{
  "name": "app-compiler",
  "version": "1.0.0",
  "description": "Compiler system: Natural language → Production-ready executable applications",
  "main": "backend/index.ts",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "tsx watch backend/index.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "tsc && cd frontend && npm run build",
    "start": "node dist/backend/index.js",
    "test": "jest",
    "evaluate": "tsx evaluation/run-evaluation.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "keywords": ["compiler", "code-generation", "app-builder", "nlp", "schema"],
  "author": "vaish4991",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "openai": "^4.24.0",
    "typescript": "^5.3.3",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4",
    "uuid": "^9.0.1",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "axios": "^1.6.2",
    "generate-password": "^1.7.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "tsx": "^4.7.0",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2"
  }
}
